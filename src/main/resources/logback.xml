<configuration>
    <!-- the correlation id (set by CorrelationFilter from X-Correlation-Id) rides every line as
         [cid=...], matching the [cid=%X{cid}] the other services print, so Loki can grep one
         request across the whole stack -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [cid=%X{cid}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
